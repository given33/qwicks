{
  "name": "qwicks",
  "version": "0.1.0",
  "description": "QWicks local HTTP/SSE agent runtime",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    },
    "./domain": {
      "types": "./dist/domain/index.d.ts",
      "import": "./dist/domain/index.js"
    },
    "./ports": {
      "types": "./dist/ports/index.d.ts",
      "import": "./dist/ports/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./loop": {
      "types": "./dist/loop/index.d.ts",
      "import": "./dist/loop/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "import": "./dist/cache/index.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "import": "./dist/telemetry/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    }
  },
  "bin": {
    "qwicks": "./dist/cli/serve-entry.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:dream": "vitest run src/dream",
    "eval:gate": "tsc -p tsconfig.build.json && node --experimental-strip-types ./scripts/eval-gate.mts",
    "transcript:diff": "node ./scripts/transcript-diff.mjs",
    "serve": "node ./dist/cli/serve-entry.js",
    "dev": "tsc -p tsconfig.build.json --watch"
  },
  "dependencies": {
    "@computer-use/nut-js": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/curves": "^1.9.7",
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.8.0",
    "better-sqlite3": "^12.10.0",
    "bonjour-service": "^1.4.1",
    "diff": "^8.0.4",
    "jimp": "^1.6.0",
    "proxy-agent": "^8.0.2",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.2",
    "vitest": "^4.1.7"
  }
}
