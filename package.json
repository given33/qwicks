{
  "name": "teamflow-desktop-root",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "prepare:sidecar": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\prepare-tauri-sidecar.ps1",
    "dev": "npm run prepare:sidecar && npx tauri dev",
    "build": "npm run prepare:sidecar && npx tauri build",
    "web:dev": "npm --prefix web run web:dev",
    "web:build": "npm --prefix web run web:build",
    "web:install": "npm --prefix web install"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0"
  }
}
